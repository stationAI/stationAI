# =========================================================================
# StationAI MVP - Environment Configuration Template
# =========================================================================
# Copy this file to a new file named ".env" in this directory:
#   cp .env.example .env
# Then fill in your real Supabase & Redis credentials.
# =========================================================================

# 🏢 Supabase Tenant Database Configuration
# Find these in your Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://ryzojlkwxvtrofdbrwzx.supabase.co
SUPABASE_KEY=your_supabase_anon_public_key

# 🔄 Redis Session Cache Configuration
# Default local Redis URL:
REDIS_URL=redis://localhost:6379/0

# 🧠 RunPod Serverless GPU Inference (Optional for production)
# Fill these in once you deploy the Whisper, Gemma 4, and Chatterbox containers
RUNPOD_API_URL=https://api.runpod.ai/v1/your_container_id/openai/v1
RUNPOD_API_KEY=your_runpod_api_key

# 🚀 FastAPI Server Bind Configuration
HOST=0.0.0.0
PORT=8000
